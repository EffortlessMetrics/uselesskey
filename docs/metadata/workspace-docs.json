      "run_smoke": true
    },
    {
      "name": "deterministic_mode",
      "path": "crates/uselesskey/examples/deterministic_mode.rs",
      "feature_set": "rsa,ecdsa,ed25519",
      "description": "Order-independent deterministic derivation guarantees",
      "run_smoke": false
    },
    {
      "name": "jwk_generation",
      "path": "crates/uselesskey/examples/jwk_generation.rs",
      "feature_set": "ecdsa,ed25519,hmac,rsa,jwk",
      "description": "Build JWKs and JWKS with `JwksBuilder` across key types",
      "run_smoke": false
    },
    {
      "name": "jwk_jwks",
      "path": "crates/uselesskey/examples/jwk_jwks.rs",
      "feature_set": "ecdsa,ed25519,hmac,rsa,jwk",
      "description": "JWK sets from multiple key types with metadata inspection",
      "run_smoke": false
    },
    {
      "name": "jwks",
      "path": "crates/uselesskey/examples/jwks.rs",
      "feature_set": "rsa,ecdsa,jwk",
      "description": "Build a JWKS from RSA and ECDSA public keys",
      "run_smoke": false
    },
    {
      "name": "jwks_server_mock",
      "path": "crates/uselesskey/examples/jwks_server_mock.rs",
      "feature_set": "rsa,ecdsa,ed25519,jwk",
      "description": "Generate a JWKS response body for a mock `/.well-known/jwks.json` endpoint",
