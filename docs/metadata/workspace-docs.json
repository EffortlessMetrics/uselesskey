    },
    {
      "name": "jwt_signing",
      "path": "crates/uselesskey/examples/jwt_signing.rs",
      "feature_set": "rsa,jwk",
      "description": "JWT signing with deterministic RSA, ECDSA, and HMAC keys (ECDSA/HMAC optional)",
