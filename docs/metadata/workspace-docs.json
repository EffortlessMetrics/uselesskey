      "description": "Realistic API keys, bearer tokens, and OAuth tokens for tests",
      "run_smoke": true
    },
    {
      "name": "x509_certificates",
      "path": "crates/uselesskey/examples/x509_certificates.rs",
      "feature_set": "x509",
      "description": "Self-signed certs, cert chains, and negative X.509 fixtures",
      "run_smoke": true
    }
  ],
  "facade_feature_matrix": [
    {
      "feature": "rsa",
      "extension_trait": "RsaFactoryExt",
      "algorithms": "RSA 2048/3072/4096 \u2014 PKCS#8, SPKI, PEM, DER",
      "implies": "-"
    },
    {
      "feature": "ecdsa",
      "extension_trait": "EcdsaFactoryExt",
      "algorithms": "P-256 (ES256), P-384 (ES384) \u2014 PKCS#8, SPKI",
      "implies": "-"
    },
    {
      "feature": "ed25519",
      "extension_trait": "Ed25519FactoryExt",
      "algorithms": "Ed25519 \u2014 PKCS#8, SPKI",
      "implies": "-"
    },
    {
      "feature": "hmac",
      "extension_trait": "HmacFactoryExt",
      "algorithms": "HS256, HS384, HS512",
      "implies": "-"
    },
    {
      "feature": "pgp",
      "extension_trait": "PgpFactoryExt",
      "algorithms": "OpenPGP RSA 2048/3072, Ed25519 \u2014 armored, binary",
      "implies": "-"
    },
    {
      "feature": "token",
      "extension_trait": "TokenFactoryExt",
      "algorithms": "API key, bearer access token, and OAuth access token",
      "implies": "-"
    },
    {
      "feature": "x509",
      "extension_trait": "X509FactoryExt",
      "algorithms": "Self-signed certs, cert chains, negative certs",
      "implies": "rsa"
    },
    {
      "feature": "jwk",
      "extension_trait": "-",
      "algorithms": "JWK/JWKS output for all enabled key types",
      "implies": "-"
    },
    {
      "feature": "all-keys",
      "extension_trait": "-",
      "algorithms": "(bundle)",
      "implies": "rsa ecdsa ed25519 hmac pgp"
    },
    {
      "feature": "full",
      "extension_trait": "-",
      "algorithms": "(everything)",
      "implies": "all-keys token x509 jwk"
    }
  ],
