{
  "workspace_crates": [
    {
      "name": "uselesskey",
      "description": "Public facade \u2014 re-exports all key types and traits behind feature flags"
    },
    {
      "name": "uselesskey-core",
      "description": "Factory, deterministic derivation, caching, and negative-fixture helpers"
    },
    {
      "name": "uselesskey-rsa",
      "description": "RSA 2048/3072/4096 keypairs (PKCS#8, SPKI, PEM, DER)"
    },
    {
      "name": "uselesskey-ecdsa",
      "description": "ECDSA P-256 / P-384 keypairs"
    },
    {
      "name": "uselesskey-ed25519",
      "description": "Ed25519 keypairs"
    },
    {
      "name": "uselesskey-hmac",
      "description": "HMAC HS256/HS384/HS512 secrets"
    },
    {
      "name": "uselesskey-pgp",
      "description": "OpenPGP key fixtures (armored + binary keyblocks)"
    },
    {
      "name": "uselesskey-token",
      "description": "API key, bearer token, and OAuth access-token fixtures"
    },
    {
      "name": "uselesskey-jwk",
      "description": "Typed JWK/JWKS models and builders"
    },
    {
      "name": "uselesskey-x509",
      "description": "X.509 self-signed certificates and certificate chains"
    }
  ],
  "adapter_crates": [
    {
      "name": "uselesskey-jsonwebtoken",
      "description": "`jsonwebtoken` `EncodingKey` / `DecodingKey`"
    },
    {
      "name": "uselesskey-jose-openid",
      "description": "JOSE/OpenID-oriented native `jsonwebtoken` key conversions"
    },
    {
      "name": "uselesskey-pgp-native",
      "description": "Native `pgp` `SignedSecretKey` / `SignedPublicKey` adapters"
    },
    {
      "name": "uselesskey-rustls",
      "description": "`rustls` `ServerConfig` / `ClientConfig` builders"
    },
    {
      "name": "uselesskey-tonic",
      "description": "`tonic::transport` TLS identity / config for gRPC"
    },
    {
      "name": "uselesskey-ring",
      "description": "`ring` 0.17 native signing key types"
    },
    {
      "name": "uselesskey-rustcrypto",
      "description": "RustCrypto native types (`rsa::RsaPrivateKey`, etc.)"
    },
    {
      "name": "uselesskey-aws-lc-rs",
      "description": "`aws-lc-rs` native types"
    }
  ],
  "runnable_examples": [
    {
      "name": "adapter_jsonwebtoken",
      "path": "crates/uselesskey/examples/adapter_jsonwebtoken.rs",
      "feature_set": "rsa,ecdsa,ed25519,hmac",
      "description": "Sign and verify JWTs using `jsonwebtoken` crate integration",
      "run_smoke": false
    },
    {
      "name": "adapter_rustls",
      "path": "crates/uselesskey/examples/adapter_rustls.rs",
      "feature_set": "x509",
      "description": "Convert X.509 fixtures into rustls `ServerConfig` / `ClientConfig`",
      "run_smoke": true
    },
    {
      "name": "basic_ecdsa",
      "path": "crates/uselesskey/examples/basic_ecdsa.rs",
      "feature_set": "ecdsa,jwk",
      "description": "Generate ECDSA keypairs for P-256 and P-384 in PEM, DER, JWK",
      "run_smoke": true
    },
    {
      "name": "basic_ed25519",
      "path": "crates/uselesskey/examples/basic_ed25519.rs",
      "feature_set": "ed25519,jwk",
      "description": "Generate Ed25519 keypairs in PEM, DER, and JWK formats",
      "run_smoke": true
    },
    {
      "name": "basic_hmac",
      "path": "crates/uselesskey/examples/basic_hmac.rs",
      "feature_set": "hmac,jwk",
      "description": "Generate HMAC secrets for HS256, HS384, and HS512",
      "run_smoke": true
    },
    {
      "name": "basic_rsa",
      "path": "crates/uselesskey/examples/basic_rsa.rs",
      "feature_set": "rsa,jwk",
      "description": "Generate RSA keypairs in PEM, DER, and JWK formats",
      "run_smoke": true
    },
    {
      "name": "basic_token",
      "path": "crates/uselesskey/examples/basic_token.rs",
      "feature_set": "token",
      "description": "Generate API key, bearer token, and OAuth access-token fixtures",
      "run_smoke": true
    },
    {
      "name": "basic_usage",
      "path": "crates/uselesskey/examples/basic_usage.rs",
      "feature_set": "ecdsa,ed25519,rsa,jwk",
      "description": "All-in-one: RSA, ECDSA, and Ed25519 fixture generation",
      "run_smoke": false
    },
    {
      "name": "deterministic",
      "path": "crates/uselesskey/examples/deterministic.rs",
      "feature_set": "rsa",
